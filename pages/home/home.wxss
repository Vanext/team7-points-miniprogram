/* pages/home/home.wxss */
page {
  background: #f5f6fb;
}

.container {
  padding: 20rpx; /* Reduced padding */
}

/* Brand Header */
.brand-header {
  background: linear-gradient(180deg, #1a237e, #2c3aa8);
  padding: 30rpx 24rpx; /* Reduced padding */
  border-radius: 20rpx;
  margin-bottom: 20rpx; /* Reduced margin */
  color: white;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(26, 35, 126, 0.3);
}

.brand-info .slogan {
  font-size: 36rpx; /* Larger slogan since title is gone */
  font-weight: bold;
  font-style: italic;
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.brand-info .sub-slogan {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 6rpx;
}

.brand-info .motto {
  font-size: 22rpx;
  opacity: 0.8;
  display: block;
}

/* User Info Card */
.user-info-card {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx; /* Reduced padding */
  margin-bottom: 20rpx; /* Reduced margin */
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.user-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.status-badge.activated {
  background: #e8f5e9;
  color: #4caf50;
}

.status-badge.inactive {
  background: #fff3e0;
  color: #ff9800;
}

.points-display {
  width: 140rpx; /* Slightly smaller */
  height: 140rpx;
  background: #1a237e; /* Unified with main color */
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: white;
  box-shadow: 0 4rpx 8rpx rgba(26, 35, 126, 0.2);
}

.points-number {
  font-size: 44rpx;
  font-weight: bold;
  color: white; /* Ensure white */
  line-height: 1.2;
}

.points-label {
  font-size: 22rpx;
  opacity: 0.9;
  color: white;
}

/* Action Grid */
.action-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr); /* 3 columns for compactness */
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-item {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.action-icon {
  font-size: 56rpx; /* Slightly smaller */
  margin-bottom: 12rpx;
}

.action-icon-img {
  width: 70rpx;
  height: 70rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* Announcements */
.announcements-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.announcement-header { margin-bottom: 16rpx; }
.ann-label { font-size: 32rpx; font-weight: bold; color: #333; }
.announcements-swiper { height: 220rpx; }
.announcements-swiper.expanded { height: auto; }

.announcement-item { display: flex; flex-direction: column; height: 220rpx; }
.announcement-item.expanded { height: auto; }

.ann-row-top { display: flex; align-items: center; margin-bottom: 8rpx; }

.tag { background: #ff9800; color: white; font-size: 20rpx; padding: 4rpx 10rpx; border-radius: 6rpx; margin-right: 12rpx; }

.ann-title { font-size: 28rpx; font-weight: 500; color: #333; }
.ann-time { font-size: 22rpx; color: #999; margin-bottom: 8rpx; }
.ann-content-scroll { height: 140rpx; overflow: hidden; }
.ann-content { font-size: 26rpx; color: #666; line-height: 1.6; white-space: pre-wrap; }

/* Camp Section Banner */
.camp-section {
  margin-bottom: 20rpx;
}

.camp-card {
  background: linear-gradient(90deg, #d32f2f, #e53935);
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(211, 47, 47, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.camp-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.camp-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.camp-title {
  font-size: 30rpx;
  font-weight: bold;
}

.camp-subtitle {
  font-size: 22rpx;
  opacity: 0.9;
}

/* Partners Section */
.partners-section {
  margin-top: 10rpx;
}

.partners-header { margin-bottom: 12rpx; padding: 0 6rpx; }
.partners-title { font-size: 28rpx; font-weight: 600; color: #333; }

.partners-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr); /* 3 columns, 2 rows */
  gap: 16rpx;
}

.partner-item {
  background: rgba(255,255,255,0.6); /* Semi-transparent white */
  border-radius: 12rpx;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #ccc;
  overflow: hidden;
}

.partner-img {
  width: 100%;
  height: 100%;
}

.partner-placeholder {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}
.ann-actions { margin-top: 8rpx; display: flex; justify-content: flex-end; }
.ann-action-btn { color: #1a237e; font-size: 24rpx; }
.ann-content-expanded { max-height: none; }
.ann-content-scroll { max-height: 140rpx; }
.ann-content { font-size: 26rpx; color: #666; line-height: 1.6; white-space: pre-wrap; }

/* Bulletin Card */
.bulletin-card { background: white; border-radius: 20rpx; padding: 20rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05); }
.bulletin-header { display:flex; justify-content: space-between; align-items: baseline; margin-bottom: 8rpx; }
.bulletin-swiper { height: 240rpx; }
.bulletin-slide { padding-bottom: 10rpx; }
.bulletin-subheader { display:flex; justify-content: flex-start; align-items: center; gap: 8rpx; margin-bottom: 8rpx; }
.bulletin-title { font-size: 32rpx; font-weight: bold; color:#333; white-space: normal; word-break: break-word; line-height: 1.3; }
.bulletin-time { font-size: 22rpx; color:#666; }
.bulletin-sep { font-size: 22rpx; color:#aaa; }
.bulletin-location { font-size: 22rpx; color:#666; }
.bulletin-content-box { }
.bulletin-content { font-size: 26rpx; color:#333; line-height:1.7; white-space: pre-wrap; word-break: break-word; display: block; }
.bulletin-actions { margin-top: 12rpx; display:flex; align-items:flex-start; gap: 12rpx; }
.join-btn { background:#1a237e; color:#fff; border-radius: 7rpx; padding: 5rpx 12rpx; display:inline-block; font-size: 24rpx; line-height: normal; }
.participants-area { flex: 1; min-width: 0; }
.participants-wrap { display: flex; flex-wrap: wrap; gap: 10rpx; }
.participant-tag { background: rgba(26,35,126,0.08); color: #1a237e; border: 1rpx solid rgba(26,35,126,0.18); padding: 6rpx 12rpx; border-radius: 999rpx; font-size: 22rpx; line-height: 1.2; max-width: 100%; word-break: break-word; }
.participants-empty { font-size: 22rpx; color: #9aa0a6; }

/* Modal Styles */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 999;
}

.modal-container {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: white;
  border-radius: 30rpx 30rpx 0 0;
  padding-bottom: 40rpx;
  z-index: 1000;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 0 10rpx;
}

.modal-content {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.info-section {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  color: #666;
  font-size: 26rpx;
  width: 140rpx;
}

.info-val {
  color: #333;
  font-size: 26rpx;
  flex: 1;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
}

.picker-view {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  line-height: 80rpx;
}

.picker-view.placeholder {
  color: #999;
}

.date-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx; /* Reduced gap */
}

.date-item {
  width: calc(25% - 9rpx); /* 4 items per row */
  height: 64rpx; /* Reduced height */
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx; /* Reduced font size */
  color: #666;
  border: 2rpx solid transparent;
}

.date-item.selected {
  background: #fff3e0;
  color: #ff9800;
  border-color: #ff9800;
  font-weight: bold;
}

.selected-days-tip {
  font-size: 24rpx;
  color: #ff9800;
  margin-top: 12rpx;
  text-align: right;
  padding-right: 4rpx; /* Prevent edge overflow */
}

.modal-footer {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
}

.submit-btn {
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
}
