<!--pages/home/home.wxml-->
<view class="container">
  <!-- Brand Header -->
  <view class="brand-header">
    <view class="brand-info">
      <text class="slogan">TEAM 7</text>
      <text class="sub-slogan">From zero to hero</text>
      <text class="motto">一群人，一件事，一7拼，一7赢</text>
    </view>
  </view>

  <!-- User Info Card -->
  <view class="card user-info-card">
    <view class="user-section">
      <view class="user-details">
        <view class="user-text-info">
           <view class="user-name">{{isLoggedIn ? (userInfo.nickName || '微信用户') : '未登录'}}</view>
           <view class="user-status-wrapper">
             <text class="status-badge {{userInfo.isExchangeActivated ? 'activated' : 'inactive'}}">
               {{userInfo.isExchangeActivated ? '已激活' : '未激活'}}
             </text>
           </view>
        </view>
      </view>
      <view class="points-display">
        <text class="points-number">{{userInfo.totalPoints || 0}}</text>
        <text class="points-label">积分</text>
      </view>
    </view>
  </view>

  <!-- Banner -->
  <view class="camp-section" wx:if="{{false}}">
    <!-- Youth Training Recruitment Card -->
    <view class="camp-card youth-card" bindtap="openYouthModal" style="margin-top: 0; background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);">
      <view class="camp-row">
        <text class="camp-icon">🚴</text>
        <text class="camp-title">Team7青少年骑跑训练招募</text>
      </view>
      <text class="camp-subtitle">立即报名</text>
    </view>
  </view>

  <!-- Menu Grid -->
  <view class="action-grid">
    <view class="action-item" bindtap="navigateToUpload">
      <image class="action-icon-img" src="/images/icon-upload.png" wx:if="{{false}}"></image>
      <view class="action-icon" wx:else>📷</view>
      <text class="action-text">上传打卡</text>
    </view>
    <view class="action-item" bindtap="navigateToStore">
      <image class="action-icon-img" src="/images/icon-store.png" wx:if="{{false}}"></image>
      <view class="action-icon" wx:else>🛍️</view>
      <text class="action-text">积分兑换</text>
    </view>
    <view class="action-item" bindtap="navigateToLeaderboard">
      <image class="action-icon-img" src="/images/icon-rank.png" wx:if="{{false}}"></image>
      <view class="action-icon" wx:else>🏆</view>
      <text class="action-text">排行榜</text>
    </view>
    <view class="action-item" bindtap="navigateToTrainingAssistant">
      <view class="action-icon">📊</view>
      <text class="action-text">竞训助手</text>
    </view>
    <view class="action-item" bindtap="navigateToTools">
      <view class="action-icon">🛠️</view>
      <text class="action-text">铁人助手</text>
    </view>
    <view class="action-item" bindtap="navigateToProfile">
      <image class="action-icon-img" src="/images/icon-user.png" wx:if="{{false}}"></image>
      <view class="action-icon" wx:else>👤</view>
      <text class="action-text">个人中心</text>
    </view>
  </view>

  <!-- Announcements -->
  <view class="card announcements-card" wx:if="{{announcements.length > 0}}">
    <view class="announcement-header">
      <text class="ann-label">公告</text>
    </view>
    <swiper class="announcements-swiper" autoplay="true" interval="5000" circular="true" indicator-dots="true" bindchange="onAnnSwiperChange">
      <block wx:for="{{announcements}}" wx:key="_id" wx:for-index="index">
        <swiper-item>
          <view class="announcement-item">
            <view class="ann-row-top">
              <text class="tag">通知</text>
              <text class="ann-title">{{item.title}}</text>
            </view>
            <text class="ann-time">{{item.createTime}}</text>
            <scroll-view scroll-y="true" class="ann-content-scroll" scroll-top="{{annScrollTop}}">
              <text class="ann-content">{{item.content}}</text>
            </scroll-view>
          </view>
        </swiper-item>
      </block>
    </swiper>
  </view>

  <!-- Training Bulletins Carousel -->
  <view class="card bulletin-card" wx:if="{{bulletins.length > 0}}">
    <view class="bulletin-header">
      <text class="bulletin-title">{{(bulletins[currentBulletinIndex] && bulletins[currentBulletinIndex].title) || '训练通告'}}</text>
    </view>
    <swiper class="bulletin-swiper" autoplay="true" interval="5000" circular="true" indicator-dots="true" bindchange="onBulletinSwiperChange" style="height: {{bulletinSwiperHeight}}px;">
      <block wx:for="{{bulletins}}" wx:key="_id">
        <swiper-item>
          <view id="bulletin-slide-{{item._id}}" class="bulletin-slide">
            <view class="bulletin-subheader">
              <text class="bulletin-time">{{item.time}}</text>
              <text class="bulletin-sep">·</text>
              <text class="bulletin-location">{{item.location}}</text>
            </view>
            <view class="bulletin-content-box">
              <text class="bulletin-content">{{item.content}}</text>
            </view>
            <view class="bulletin-actions">
              <view class="join-btn" data-id="{{item._id}}" bindtap="toggleJoinBulletin">{{joinedMap[item._id] ? '取消' : '接龙'}}</view>
              <view class="participants-area">
                <view class="participants-wrap" wx:if="{{item.participants && item.participants.length > 0}}">
                  <block wx:for="{{item.participants}}" wx:key="openid" wx:for-item="p">
                    <view class="participant-tag">{{p.nickName}}</view>
                  </block>
                </view>
                <text class="participants-empty" wx:else>暂无接龙</text>
              </view>
            </view>
          </view>
        </swiper-item>
      </block>
    </swiper>
  </view>

  <!-- Ironman Camp Card -->
  <view class="camp-section">
    <view class="camp-card" bindtap="onJoinCamp">
      <view class="camp-row">
        <text class="camp-icon">🏃</text>
        <text class="camp-title">IRONMAN 70.3 横琴训练营</text>
      </view>
      <text class="camp-subtitle">{{campStatus === 'approved' ? '立即加入' : '申请入营'}}</text>
    </view>
  </view>

  <!-- Youth Training Modal -->
  <wxs module="util">
  function includes(arr, val) {
    return arr.indexOf(val) > -1;
  }
  module.exports.includes = includes;
  </wxs>
  <view class="modal-mask" wx:if="{{showYouthModal}}" bindtap="closeYouthModal"></view>
  <view class="modal-container" wx:if="{{showYouthModal}}">
    <view class="modal-header">
      <text class="modal-title">青少年骑跑训练报名</text>
      <view class="modal-close" bindtap="closeYouthModal">✕</view>
    </view>
    <scroll-view scroll-y="true" class="modal-content">
      <view class="info-section">
        <view class="info-row"><text class="info-label">时间：</text><text class="info-val">2月6日-2月14日</text></view>
        <view class="info-row"><text class="info-label">训练时间：</text><text class="info-val">早9点-11点30</text></view>
        <view class="info-row"><text class="info-label">地点：</text><text class="info-val">渝中区滨江路</text></view>
        <view class="info-row"><text class="info-label">费用：</text><text class="info-val">单次140/人，5天起缴</text></view>
      </view>
      
      <view class="form-group">
        <view class="form-item">
          <text class="form-label">姓名</text>
          <input class="form-input" placeholder="请输入姓名" value="{{youthForm.name}}" data-field="name" bindinput="onYouthInput" />
        </view>

        <view class="form-item">
          <text class="form-label">性别</text>
          <picker range="{{genderOptions}}" bindchange="onGenderChange">
            <view class="picker-view {{youthForm.gender ? '' : 'placeholder'}}">
              {{youthForm.gender || '请选择性别'}}
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">年龄</text>
          <input class="form-input" type="number" placeholder="请输入年龄" value="{{youthForm.age}}" data-field="age" bindinput="onYouthInput" />
        </view>
        <view class="form-item">
          <text class="form-label">身高(cm)</text>
          <input class="form-input" type="number" placeholder="请输入身高" value="{{youthForm.height}}" data-field="height" bindinput="onYouthInput" />
        </view>

        <view class="form-item">
          <text class="form-label">是否自带意外险</text>
          <picker range="{{insuranceOptions}}" bindchange="onInsuranceChange">
            <view class="picker-view {{youthForm.hasInsurance ? '' : 'placeholder'}}">
              {{youthForm.hasInsurance || '请选择'}}
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">参加日期（可多选）</text>
          <view class="date-grid">
            <block wx:for="{{availableDates}}" wx:key="id">
              <view class="date-item {{util.includes(youthForm.days, item.date) ? 'selected' : ''}}" 
                    bindtap="toggleDateSelection" 
                    data-date="{{item.date}}">
                {{item.date}}
              </view>
            </block>
          </view>
          <view class="selected-days-tip" wx:if="{{youthForm.days.length}}">已选：{{youthForm.days.length}}天</view>
        </view>

        <view class="form-item">
          <text class="form-label">联系人</text>
          <input class="form-input" placeholder="请输入联系人姓名" value="{{youthForm.contactPerson}}" data-field="contactPerson" bindinput="onYouthInput" />
        </view>
        <view class="form-item">
          <text class="form-label">联系电话</text>
          <input class="form-input" type="number" placeholder="请输入联系电话" value="{{youthForm.contactPhone}}" data-field="contactPhone" bindinput="onYouthInput" />
        </view>
      </view>
    </scroll-view>
    <view class="modal-footer">
      <button class="submit-btn" bindtap="submitYouthForm" loading="{{youthSubmitting}}">提交报名</button>
    </view>
  </view>


  

  <!-- Partners Section -->
  <view class="partners-section">
    <view class="partners-header">
      <text class="partners-title">合作伙伴</text>
    </view>
    <view class="partners-grid">
      <block wx:for="{{partners}}" wx:key="index">
        <view class="partner-item" bindtap="uploadPartnerImage" data-index="{{index}}">
          <image class="partner-img" src="{{item.url}}" mode="aspectFit" wx:if="{{item.url}}"></image>
          <view class="partner-placeholder" wx:else></view>
        </view>
      </block>
    </view>
  </view>
</view>
