page { background: #f5f5f5; }
.container { padding: 20rpx; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.title { font-size: 32rpx; font-weight: bold; }
.export-btn { background: #1a237e; color: white; margin: 0; }

.card { background: white; border-radius: 12rpx; padding: 20rpx; margin-bottom: 20rpx; }
.row { display: flex; margin-bottom: 10rpx; font-size: 28rpx; }
.header-row { justify-content: space-between; border-bottom: 1rpx solid #eee; padding-bottom: 10rpx; margin-bottom: 16rpx; }
.name { font-weight: bold; font-size: 30rpx; }
.time { color: #999; font-size: 24rpx; }
.label { color: #666; width: 160rpx; }
.value { color: #333; flex: 1; }
.days-row { flex-direction: column; }
.days-list { margin-top: 6rpx; color: #1a237e; background: #e8eaf6; padding: 10rpx; border-radius: 8rpx; }
.action-row { margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx dashed #eee; display: flex; justify-content: flex-end; }
.delete-btn { background: #f44336; color: white; margin: 0; font-size: 24rpx; }
.loading, .empty { text-align: center; color: #999; padding: 20rpx; }
.list-container { height: 85vh; }
