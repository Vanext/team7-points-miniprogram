<!--pages/admin/members/members.wxml-->
<view class="container">
  <block wx:if="{{!isAdmin}}">
    <view class="no-access-card">
      <view class="no-access-icon">🔒</view>
      <view class="no-access-title">权限不足</view>
      <view class="no-access-desc">只有管理员才能访问此页面</view>
    </view>
  </block>
  <block wx:else>
    <!-- 顶部统计与搜索区 (吸顶) -->
    <view class="header-section">
      <view class="stats-row">
        <text class="page-title">成员管理</text>
        <text class="stats-info">总人数 {{totalCount}}｜正式会员 {{officialCount}}</text>
      </view>

      <view class="search-bar">
        <view class="search-input-wrap">
          <text class="search-icon">🔍</text>
          <input class="search-input" placeholder="搜索昵称或OpenID" bindinput="onKeyword" value="{{keyword}}"/>
        </view>
        <button class="btn-primary search-btn" bindtap="onSearch">搜索</button>
      </view>
      
      <view class="filter-row">
        <view class="sort-group">
          <view class="sort-item {{sortBy==='joinDate'?'active':''}}" bindtap="onSortByJoinDate">按注册</view>
          <view class="sort-item {{sortBy==='points'?'active':''}}" bindtap="onSortByPoints">按积分</view>
          <view class="sort-item {{sortBy==='name'?'active':''}}" bindtap="onSortByName">按姓名</view>
        </view>
        <view class="action-group">
          <view class="export-btn" bindtap="onExportData" disabled="{{loading || list.length === 0}}">
            <text>导出数据</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 成员列表 -->
    <scroll-view scroll-y class="members-scroll" enable-back-to-top bindscrolltolower="onLoadMore" lower-threshold="100">
      <view class="members-list">
        <block wx:for="{{list}}" wx:key="_id">
          <view class="member-card" bindtap="onOpenMemberModal" data-id="{{item._id}}">
            <!-- 上半部分：信息展示 -->
            <view class="card-main">
              <view class="info-column">
                <view class="name-row">
                  <text class="user-name">{{item.nickName || '未知用户'}}</text>
                  <!-- 锁状态指示器 (图标) -->
                  <text class="lock-indicator" wx:if="{{item.isOfficialMember && item.exchange_locked}}">🔒</text>
                </view>
                <view class="tags-row">
                  <!-- 文本标签，清晰易懂 -->
                  <text class="tag admin" wx:if="{{item.isAdmin}}">管理员</text>
                  <text class="tag" wx:if="{{item.registerDateText}}">注册 {{item.registerDateText}}</text>
                  <text class="tag official" wx:if="{{item.isOfficialMember}}">正式会员</text>
                  <text class="tag paid" wx:if="{{item.isOfficialMember && item.officialMemberUntilText}}">到期 {{item.officialMemberUntilText}}</text>
                  <text class="tag guest" wx:if="{{!item.isOfficialMember}}">普通用户</text>
                  <text class="tag active" wx:if="{{item.isExchangeActivated}}">已激活</text>
                  <text class="tag inactive" wx:if="{{item.isOfficialMember && !item.isExchangeActivated}}">未激活</text>
                </view>
              </view>
              
              <view class="points-column">
                <text class="points-val {{item.totalPoints < 0 ? 'negative' : ''}}">{{item.totalPoints || 0}}</text>
                <text class="points-unit">分</text>
              </view>
            </view>

            <!-- 下半部分：操作区域 -->
            <view class="card-actions" catchtap="noop">
              <!-- 积分设置 -->
              <view class="action-group-left">
                <input 
                  class="points-input" 
                  type="number" 
                  placeholder="±积分" 
                  data-id="{{item._id}}" 
                  bindinput="onNewPointsInput"
                  value="{{newPointsMap[item._id] || ''}}"
                />
                <view class="btn-small primary" data-id="{{item._id}}" bindtap="onSetPoints">修改</view>
              </view>
              
              <!-- 状态切换按钮 (带文字) -->
              <view class="action-group-right">
                <view class="btn-text {{item.isAdmin ? 'active' : ''}}" catchtap="toggleAdminStatus" data-user-id="{{item._id}}" data-is-admin="{{item.isAdmin}}" data-nick-name="{{item.nickName}}">
                  管理员
                </view>
                <view class="btn-text {{item.isOfficialMember ? 'active' : ''}}" catchtap="toggleOfficialMember" data-user-id="{{item._id}}" data-is-official="{{item.isOfficialMember}}" data-nick-name="{{item.nickName}}">
                  正式会员
                </view>
                <view class="btn-text {{item.exchange_locked ? 'danger' : ''}}" catchtap="toggleExchangeLock" data-user-id="{{item._id}}" data-is-locked="{{item.exchange_locked}}" data-nick-name="{{item.nickName}}" wx:if="{{item.isOfficialMember}}">
                  {{item.exchange_locked ? '解锁' : '锁定'}}
                </view>
                <view class="btn-text danger" catchtap="onDeleteMember" data-user-id="{{item._id}}" data-nick-name="{{item.nickName}}">
                  删除
                </view>
              </view>
            </view>
          </view>
        </block>

        <view class="member-modal-mask" wx:if="{{memberModalVisible}}" catchtap="onCloseMemberModal">
          <view class="member-modal" catchtap="noop">
            <view class="member-modal-header">
              <text class="member-modal-title">成员设置</text>
              <view class="member-modal-close" catchtap="onCloseMemberModal">✕</view>
            </view>

            <view class="member-modal-body">
              <view class="member-modal-row">
                <text class="member-modal-label">昵称</text>
                <text class="member-modal-value">{{memberModalUser.nickName || '未知用户'}}</text>
              </view>
              <view class="member-modal-row">
                <text class="member-modal-label">积分</text>
                <text class="member-modal-value">{{memberModalUser.totalPoints || 0}}</text>
              </view>
              <view class="member-modal-row">
                <text class="member-modal-label">正式会员</text>
                <text class="member-modal-value">{{memberModalUser.isOfficialMember ? '是' : '否'}}</text>
              </view>
              <view class="member-modal-row">
                <text class="member-modal-label">兑换状态</text>
                <text class="member-modal-value">{{memberModalUser.isExchangeActivated ? '已激活' : (memberModalUser.isOfficialMember ? '未激活' : '-') }}</text>
              </view>

              <view class="member-modal-section">
                <view class="member-modal-section-title">到期日期</view>
                <picker mode="date" value="{{memberModalExpiryDate}}" bindchange="onMemberExpiryChange">
                  <view class="member-modal-picker">
                    <text class="member-modal-picker-text">{{memberModalExpiryDate || '请选择日期'}}</text>
                    <text class="member-modal-picker-arrow">›</text>
                  </view>
                </picker>
                <view class="member-modal-hint" wx:if="{{!memberModalUser.isOfficialMember}}">保存将自动设为正式会员</view>
              </view>
            </view>

            <view class="member-modal-footer">
              <view class="member-modal-btn" catchtap="onCloseMemberModal">取消</view>
              <view class="member-modal-btn primary" catchtap="onSaveMemberExpiry" wx:if="{{memberModalExpiryDate}}">保存</view>
            </view>
          </view>
        </view>
        
        <view class="loading-state" wx:if="{{loading}}">
          <text>加载中...</text>
        </view>
        
        <view class="empty-state" wx:if="{{list.length === 0 && !loading}}">
          <text>未找到匹配成员</text>
        </view>

        <view class="no-more-state" wx:if="{{noMore && list.length > 0}}">
          <text>-- 没有更多数据了 --</text>
        </view>
      </view>
    </scroll-view>
  </block>
</view>
